.ruff_cache/
htmlcov/
.coverage

# Node / frontend（根目录 npm 依赖；子包另有各自 .gitignore）
node_modules/

# Virtual env
venv/
.venv/
# 本地虚拟环境启动脚本（从 activate_oceanrace_env.sh.example 复制）
activate_oceanrace_env.sh
.env/
.env.*
!.env.example
.Python

# PyCharm
.idea/
*.iml

# VS Code
.vscode/

# Jupyter
.ipynb_checkpoints/

# Data
data/raw/*
!data/raw/README.md
data/interim/
# processed 下大文件仍忽略，但保留划分清单 JSON 可提交
data/processed/*
!data/processed/element_forecasting/
data/processed/element_forecasting/*
!data/processed/element_forecasting/path.txt
!data/processed/eddy_detection/
data/processed/eddy_detection/*
!data/processed/eddy_detection/path.txt
!data/processed/anomaly_detection/
data/processed/anomaly_detection/*
!data/processed/anomaly_detection/path.txt
!data/processed/splits/
!data/processed/splits/**
!data/processed/normalization/
!data/processed/normalization/**

# 中间训练结果（checkpoint、日志等）；最佳模型请挑选后放入 models/
outputs/*
# 各任务下定稿输出（指标、图表等）不忽略，可提交（大体积训练 run 请放 runs/ 下并保持忽略）
!outputs/eddy_detection/
!outputs/eddy_detection/**
outputs/eddy_detection/runs/
outputs/eddy_detection/runs/**
!outputs/element_forecasting/
!outputs/element_forecasting/**
!outputs/anomaly_detection/
!outputs/anomaly_detection/**

# Logs
*.log

# macOS
.DS_Store

# Windows
Thumbs.db

# dotenv
.env

# 任务配置：configs/<任务>/ 下 model.yaml、train.yaml 等随仓库维护，不采用 *.yaml.example 模板流程
# 仅敏感项单独文件：configs/*.secret（勿将密钥写入可提交的 yaml）
configs/*.secret

# Drive upload temp files
.tmp.driveupload/